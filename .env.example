# ==============================================
# TURION NETWORK — VARIAVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha
# ==============================================

# --- APLICACAO ---
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://turion.network
NEXT_PUBLIC_APP_NAME="Turion Network"

# --- BANCO DE DADOS (PostgreSQL local) ---
DATABASE_URL=postgresql://turion:TROQUE_A_SENHA@localhost:5432/turion_db
POSTGRES_USER=turion
POSTGRES_PASSWORD=TROQUE_A_SENHA
POSTGRES_DB=turion_db

# --- AUTENTICACAO (NextAuth) ---
NEXTAUTH_URL=https://turion.network
NEXTAUTH_SECRET=GERE_COM: openssl rand -base64 32

# --- AI — MODELOS LLM ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
DEEPSEEK_API_KEY=...
GROQ_API_KEY=...
OPENROUTER_API_KEY=...

# --- STRIPE (Pagamentos) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- STRIPE — IDs dos Planos ---
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...

# --- API INTERNA ---
API_URL=http://localhost:8000
API_SECRET_KEY=GERE_COM: openssl rand -hex 32

# --- REDIS (cache e filas) ---
REDIS_URL=redis://localhost:6379
